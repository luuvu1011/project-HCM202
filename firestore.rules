rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Rooms: anyone can read; only the player can write their own data
    match /rooms/{roomId} {
      allow read: if true;
      // Room state is written by server logic (host client)
      allow write: if request.auth != null;

      match /players/{playerId} {
        allow read: if true;
        // Players can only write their own document
        allow write: if request.auth != null && request.auth.uid == playerId;
      }
    }
  }
}
